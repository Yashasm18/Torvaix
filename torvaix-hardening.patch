+
+interface UseTorvaixChatReturn {
+  messages: ChatMessage[]
+  input: string
+  setInput: (value: string) => void
+  handleSubmit: (e: React.FormEvent) => void
+  isLoading: boolean
+  error: string | null
+  clearError: () => void
